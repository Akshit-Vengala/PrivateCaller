<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Contacts: decide whether an incoming number is "known" -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />

    <!-- Phone state / call handling -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.READ_CALL_LOG" />
    <!-- Place calls as the default phone app -->
    <uses-permission android:name="android.permission.CALL_PHONE" />
    <uses-permission android:name="android.permission.MANAGE_OWN_CALLS" />

    <!-- Foreground notification for an active SmartUnblock window -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- In-app updater: fetch releases from GitHub and install the APK -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <application
        android:name=".PrivateCallerApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.PrivateCaller"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.PrivateCaller">
            <!-- Required to be eligible as the default phone (dialer) app. -->
            <intent-filter>
                <action android:name="android.intent.action.DIAL" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.DIAL" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="tel" />
            </intent-filter>
        </activity>

        <!--
            Two launcher aliases let us swap the home-screen icon at runtime:
            "On" (green shield) when screening is enabled, "Off" (grey) when not.
            Exactly one is enabled at a time. Defaults to On (screening defaults on).
        -->
        <activity-alias
            android:name=".LauncherOn"
            android:enabled="true"
            android:exported="true"
            android:icon="@mipmap/ic_launcher"
            android:roundIcon="@mipmap/ic_launcher_round"
            android:label="@string/app_name"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
        <activity-alias
            android:name=".LauncherOff"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_off"
            android:roundIcon="@mipmap/ic_launcher_off_round"
            android:label="@string/app_name"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!-- Contact detail / per-contact settings screen. -->
        <activity
            android:name=".ui.ContactDetailActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:theme="@style/Theme.PrivateCaller" />

        <!-- Full-screen UI for ongoing calls when we are the default phone app. -->
        <activity
            android:name=".ui.InCallActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:launchMode="singleTop"
            android:showOnLockScreen="true"
            android:theme="@style/Theme.PrivateCaller" />

        <!-- Owns ongoing calls (answer/reject/hangup) when default phone app. -->
        <service
            android:name=".service.PrivateInCallService"
            android:exported="true"
            android:permission="android.permission.BIND_INCALL_SERVICE">
            <meta-data
                android:name="android.telecom.IN_CALL_SERVICE_UI"
                android:value="true" />
            <intent-filter>
                <action android:name="android.telecom.InCallService" />
            </intent-filter>
        </service>

        <!-- Screens every incoming call; rejects unknown numbers unless unblocked. -->
        <service
            android:name=".service.PrivateCallScreeningService"
            android:exported="true"
            android:permission="android.permission.BIND_SCREENING_SERVICE">
            <intent-filter>
                <action android:name="android.telecom.CallScreeningService" />
            </intent-filter>
        </service>

        <!-- Shares the downloaded update APK with the system installer. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.updates"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- Reads notifications from delivery/ride apps to open SmartUnblock windows. -->
        <service
            android:name=".service.SmartUnblockNotificationListener"
            android:exported="true"
            android:label="@string/smart_unblock_listener_label"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

    </application>

</manifest>
