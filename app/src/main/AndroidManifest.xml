<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Contacts: decide whether an incoming number is "known" -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />

    <!-- Phone state / call handling -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.READ_CALL_LOG" />
    <!-- Place calls as the default phone app -->
    <uses-permission android:name="android.permission.CALL_PHONE" />
    <uses-permission android:name="android.permission.MANAGE_OWN_CALLS" />

    <!-- Foreground notification for an active SmartUnblock window -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Proximity screen-off wake lock: blank the screen during a call when held to the ear -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!--
        Heads-up incoming-call banner. As the default phone app (ROLE_DIALER)
        this is auto-granted; it lets the OS show the full call screen when the
        device is locked/off and a peeking Answer/Decline banner when unlocked.
    -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />

    <!--
        SmartUnblock (notification listener) and the in-app updater
        (INTERNET + REQUEST_INSTALL_PACKAGES + FileProvider) are declared only
        in the "full" flavor: app/src/full/AndroidManifest.xml. The "playstore"
        flavor intentionally omits them so it carries none of the permissions
        that get the app flagged.
    -->

    <application
        android:name=".PrivateCallerApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.PrivateCaller"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.PrivateCaller">
            <!-- Required to be eligible as the default phone (dialer) app. -->
            <intent-filter>
                <action android:name="android.intent.action.DIAL" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.DIAL" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="tel" />
            </intent-filter>
        </activity>

        <!--
            Two launcher aliases let us swap the home-screen icon at runtime:
            "On" (green shield) when screening is enabled, "Off" (grey) when not.
            Exactly one is enabled at a time. Defaults to On (screening defaults on).
        -->
        <activity-alias
            android:name=".LauncherOn"
            android:enabled="true"
            android:exported="true"
            android:icon="@mipmap/ic_launcher"
            android:roundIcon="@mipmap/ic_launcher_round"
            android:label="@string/app_name"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
        <activity-alias
            android:name=".LauncherOff"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_off"
            android:roundIcon="@mipmap/ic_launcher_off_round"
            android:label="@string/app_name"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!-- Contact detail / per-contact settings screen. -->
        <activity
            android:name=".ui.ContactDetailActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:theme="@style/Theme.PrivateCaller" />

        <!-- Per-number call history screen. -->
        <activity
            android:name=".ui.CallHistoryActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:theme="@style/Theme.PrivateCaller" />

        <!-- Full-screen UI for ongoing calls when we are the default phone app. -->
        <activity
            android:name=".ui.InCallActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:launchMode="singleTop"
            android:showOnLockScreen="true"
            android:theme="@style/Theme.PrivateCaller" />

        <!-- Owns ongoing calls (answer/reject/hangup) when default phone app. -->
        <service
            android:name=".service.PrivateInCallService"
            android:exported="true"
            android:permission="android.permission.BIND_INCALL_SERVICE">
            <meta-data
                android:name="android.telecom.IN_CALL_SERVICE_UI"
                android:value="true" />
            <intent-filter>
                <action android:name="android.telecom.InCallService" />
            </intent-filter>
        </service>

        <!-- Screens every incoming call; rejects unknown numbers unless unblocked. -->
        <service
            android:name=".service.PrivateCallScreeningService"
            android:exported="true"
            android:permission="android.permission.BIND_SCREENING_SERVICE">
            <intent-filter>
                <action android:name="android.telecom.CallScreeningService" />
            </intent-filter>
        </service>

        <!--
            Receives Speaker / Mute / End-call taps from the ongoing-call
            notification. Non-exported: only our own PendingIntents reach it.
        -->
        <receiver
            android:name=".service.CallActionReceiver"
            android:exported="false" />

        <!--
            The FileProvider (update APK) and the SmartUnblock notification
            listener service are declared only in the "full" flavor:
            app/src/full/AndroidManifest.xml.
        -->

    </application>

</manifest>
